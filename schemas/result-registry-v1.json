{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/shsridhar-beep/svgap/schemas/result-registry-v1.json",
  "title": "SV-Gap public result registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "generated_from",
    "claim_boundary",
    "generation",
    "diagnosis",
    "repair",
    "submissions"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "registry_id": {"type": "string", "minLength": 1},
    "generated_from": {"type": "string", "minLength": 1},
    "claim_boundary": {"type": "string", "minLength": 1},
    "generation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model", "candidate_reports", "functional_statuses", "structural_statuses", "functional_pass_structural_fail", "finding_counts", "source"]
      }
    },
    "diagnosis": {"$ref": "#/$defs/challengeEntries"},
    "repair": {"$ref": "#/$defs/challengeEntries"},
    "submissions": {
      "type": "array",
      "items": {"$ref": "#/$defs/submissionEntry"}
    }
  },
  "$defs": {
    "challengeEntries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model", "run_id", "overall", "profile", "result", "submission", "provenance", "provider"],
        "properties": {
          "overall": {"enum": ["pass", "fail"]},
          "profile": {"type": "array", "minItems": 1}
        }
      }
    },
    "submissionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "submission_id", "title", "track", "configuration", "taskpack",
        "contributor", "created_at", "claim_boundary", "summary", "source"
      ],
      "properties": {
        "submission_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "track": {"enum": ["generation", "diagnosis", "repair"]},
        "configuration": {"type": "object"},
        "taskpack": {"type": "object"},
        "contributor": {"type": "string", "minLength": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "claim_boundary": {"type": "string", "minLength": 1},
        "summary": {"type": "object"},
        "source": {"type": "string", "minLength": 1}
      }
    }
  }
}
