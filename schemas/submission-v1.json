{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://svgap.dev/schemas/submission-v1.json",
  "title": "SV-Gap public result submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "submission_id", "title", "track", "configuration",
    "taskpack", "contributor", "created_at", "claim_boundary", "license",
    "artifacts", "digests"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "submission_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "title": {"type": "string", "minLength": 1},
    "track": {"enum": ["generation", "diagnosis", "repair"]},
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "provenance_level", "comparative_eligible"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "provenance_level": {
          "enum": ["public", "attested_alias", "anonymous_case_study"]
        },
        "comparative_eligible": {"type": "boolean"},
        "provider": {"type": "string", "minLength": 1},
        "model_id": {"type": "string", "minLength": 1},
        "attestation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attestor", "statement", "private_mapping_retained"],
          "properties": {
            "attestor": {"type": "string", "minLength": 1},
            "statement": {"type": "string", "minLength": 1},
            "private_mapping_retained": {"const": true}
          }
        }
      }
    },
    "taskpack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1}
      }
    },
    "contributor": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "claim_boundary": {"type": "string", "minLength": 1},
    "license": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "evidence"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "evidence": {
          "type": "array", "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "digests": {
      "type": "object",
      "minProperties": 2,
      "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
    }
  }
}
